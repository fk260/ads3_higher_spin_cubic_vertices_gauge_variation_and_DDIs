        RowBox[{"ts", ",", "dropped", ",", "kept"}], "}"}], ",", 
       RowBox[{
        RowBox[{"ts", "=", 
         RowBox[{"terms", "[", "expr", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dropped", "=", 
         RowBox[{"Select", "[", 
          RowBox[{"ts", ",", "traceTermQ"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"kept", "=", 
         RowBox[{"Complement", "[", 
          RowBox[{"ts", ",", "dropped"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\"\<kept\>\"", "->", 
           RowBox[{"Expand", "[", 
            RowBox[{"Total", "[", "kept", "]"}], "]"}]}], ",", 
          RowBox[{"\"\<dropped\>\"", "->", 
