Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Then", " ", "do", " ", "integration", " ", "by", " ", "parts", " ", "on", 
    " ", "the", " ", "contracted", " ", "derivative", " ", "pairs", " ", "to",
     " ", "form", " ", "boxes"}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
