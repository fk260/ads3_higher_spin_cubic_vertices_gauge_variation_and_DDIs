          RowBox[{"pfactors", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"mus", "=", 
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{"pfactors", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"found", "=", 
         RowBox[{
          RowBox[{"Reap", "[", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"MemberQ", "[", 
                 RowBox[{"pfactors", ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", "mu"}], "}"}]}], "]"}], "&&", 
                RowBox[{"MemberQ", "[", 
                 RowBox[{"pfactors", ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"ip1", "[", "i", "]"}], ",", "mu"}], "}"}]}], 
                 "]"}]}], ",", 
               RowBox[{"Sow", "[", 
                RowBox[{"{", 
                 RowBox[{"i", ",", 
                  RowBox[{"ip1", "[", "i", "]"}], ",", "mu"}], "}"}], "]"}]}],
               "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"mu", ",", "mus"}], "}"}]}], "]"}], "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"found", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"{", "}"}], ",", 
          RowBox[{"DeleteDuplicates", "[", 
           RowBox[{"First", "[", "found", "]"}], "]"}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"reduceAdjacentBoxPairInTerm", "[", "term_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "pairs", ",", "i", ",", "j", ",", "mu", ",", "pair", ",", 
         "replacement", ",", "rest", ",", "result"}], "}"}], ",", 
       RowBox[{
        RowBox[{"pairs", "=", 
         RowBox[{"adjacentBoxPairsInTerm", "[", "term", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"pairs", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<changed\>\"", "->", "False"}], ",", 
            RowBox[{"\"\<original\>\"", "->", "term"}], ",", 
            RowBox[{"\"\<result\>\"", "->", "term"}]}], "|>"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"i", ",", "j", ",", "mu"}], "}"}], "=", 
            RowBox[{"First", "[", "pairs", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"pair", "=", 
            RowBox[{
             RowBox[{"P", "[", 
              RowBox[{"i", ",", "mu"}], "]"}], " ", 
             RowBox[{"P", "[", 
              RowBox[{"j", ",", "mu"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"replacement", "=", 
            RowBox[{"adjacentBoxValue", "[", "i", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"rest", "=", 
            RowBox[{"term", "/", "pair"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"result", "=", 
            RowBox[{"Expand", "[", 
             RowBox[{"rest", " ", "replacement"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<changed\>\"", "->", "True"}], ",", 
             RowBox[{"\"\<original\>\"", "->", "term"}], ",", 
             RowBox[{"\"\<result\>\"", "->", "result"}]}], "|>"}]}]}], 
         "]"}]}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
