Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Simplest", " ", "first", " ", "step", " ", "is", " ", "removal", " ", 
     "of", " ", "trace"}], ",", " ", 
    RowBox[{
    "record", " ", "the", " ", "removed", " ", "terms", " ", "in", " ", "a", " ",
      "separate", " ", "list"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"Split", " ", "off", " ", "trace", " ", 
    RowBox[{"terms", ":", 
     RowBox[{"anything", " ", "containing", " ", 
      RowBox[{
       RowBox[{"U", "[", 
        RowBox[{"i", ",", "mu"}], "]"}], "^", "2"}]}]}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "terms", ",", "expandPowers", ",", "termFactors", ",", "traceTermQ", ",",
       "splitTraceTerms", ",", "ddiAfterTrace", ",", "traceDropped"}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"terms", "[", "expr_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Head", "[", 
         RowBox[{"Expand", "[", "expr", "]"}], "]"}], "===", "Plus"}], ",", 
       RowBox[{"List", "@@", 
        RowBox[{"Expand", "[", "expr", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"Expand", "[", "expr", "]"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"expandPowers", "[", "f_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"MatchQ", "[", 
        RowBox[{"f", ",", 
         RowBox[{"Power", "[", 
          RowBox[{
           RowBox[{"U", "[", 
            RowBox[{"_", ",", "_"}], "]"}], ",", 
           RowBox[{"n_Integer", "?", "Positive"}]}], "]"}]}], "]"}], ",", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{
         RowBox[{"f", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"f", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",", 
       RowBox[{"{", "f", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"termFactors", "[", "term_", "]"}], ":=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"expandPowers", "/@", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Head", "[", "term", "]"}], "===", "Times"}], ",", 
         RowBox[{"List", "@@", "term"}], ",", 
         RowBox[{"{", "term", "}"}]}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"traceTermQ", "[", "term_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "ufs", "}"}], ",", 
       RowBox[{
        RowBox[{"ufs", "=", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"termFactors", "[", "term", "]"}], ",", 
           RowBox[{
            RowBox[{"U", "[", 
             RowBox[{"i_", ",", "mu_"}], "]"}], ":>", 
