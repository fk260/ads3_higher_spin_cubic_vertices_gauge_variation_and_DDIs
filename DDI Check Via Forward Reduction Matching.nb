    RowBox[{"Adjacent", " ", "contracted", " ", "P"}], "-", 
    RowBox[{
    "pair", " ", "reduction", " ", "with", " ", "simple", " ", "term", " ", 
     "log"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"P", "[", 
      RowBox[{"i", ",", "mu"}], "]"}], " ", 
     RowBox[{"P", "[", 
      RowBox[{
       RowBox[{"i", "+", "1"}], ",", "mu"}], "]"}]}], "->", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"m", "[", 
        RowBox[{"i", "-", "1"}], "]"}], "-", 
       RowBox[{"m", "[", "i", "]"}], "-", 
       RowBox[{"m", "[", 
        RowBox[{"i", "+", "1"}], "]"}]}], ")"}], "/", "2"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "terms", ",", "expandPowers", ",", "termFactors", ",", 
      "adjacentBoxValue", ",", "adjacentBoxPairsInTerm", ",", 
      "reduceAdjacentBoxPairInTerm", ",", "reduceAdjacentBoxPairsStep"}], 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"terms", "[", "expr_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Head", "[", 
         RowBox[{"Expand", "[", "expr", "]"}], "]"}], "===", "Plus"}], ",", 
       RowBox[{"List", "@@", 
        RowBox[{"Expand", "[", "expr", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"Expand", "[", "expr", "]"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"expandPowers", "[", "f_", "]"}], ":=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"MatchQ", "[", 
        RowBox[{"f", ",", 
         RowBox[{"Power", "[", 
          RowBox[{
           RowBox[{"P", "[", 
            RowBox[{"_", ",", "_"}], "]"}], ",", 
           RowBox[{"n_Integer", "?", "Positive"}]}], "]"}]}], "]"}], ",", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{
         RowBox[{"f", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"f", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",", "True", ",", 
       RowBox[{"{", "f", "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"termFactors", "[", "term_", "]"}], ":=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"expandPowers", "/@", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Head", "[", "term", "]"}], "===", "Times"}], ",", 
         RowBox[{"List", "@@", "term"}], ",", 
         RowBox[{"{", "term", "}"}]}], "]"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"adjacentBoxValue", "[", "i_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"m", "[", 
         RowBox[{"im1", "[", "i", "]"}], "]"}], "-", 
        RowBox[{"m", "[", "i", "]"}], "-", 
        RowBox[{"m", "[", 
         RowBox[{"ip1", "[", "i", "]"}], "]"}]}], ")"}], "/", "2"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"adjacentBoxPairsInTerm", "[", "term_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"pfactors", ",", "mus", ",", "found"}], "}"}], ",", 
       RowBox[{
        RowBox[{"pfactors", "=", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"termFactors", "[", "term", "]"}], ",", 
           RowBox[{
            RowBox[{"P", "[", 
             RowBox[{"i_", ",", "mu_"}], "]"}], ":>", 
