     ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"splitTraceTerms", "[", "expr_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
