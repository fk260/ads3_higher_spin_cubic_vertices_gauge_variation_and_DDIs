PPFarLeftPlacementTest[opts : OptionsPattern[]] := Module[
   {raw, red, poly},
   raw = Block[{$labelCounter = 0}, Module[{a = pairLabel[], b = pairLabel[], c = pairLabel[]},
      {Term[1, {U[3, Cov[a]], U[1, Con[a]], P[1, Cov[b]], U[2, Con[c]], P[2, Con[b]], U[3, Cov[c]]}]}
   ]];
