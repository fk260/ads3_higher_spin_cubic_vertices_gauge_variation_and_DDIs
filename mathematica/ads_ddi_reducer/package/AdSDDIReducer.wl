        "ExpectedLength" -> 8|>,
      <|"Name" -> "same mixed word with stars",
        "Word" -> CoolIndexedWords[]["SameWordWithStars"],
        "ExpectedLength" -> 8|>,
      <|"Name" -> "short yprime word",
        "Word" -> CoolIndexedWords[]["YPrime_U3P2"],
        "ExpectedLength" -> 2|>,
      <|"Name" -> "separated multi-letter labels",
