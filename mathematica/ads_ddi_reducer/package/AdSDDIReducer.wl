ClearAll[ZWord, DivYim1Word, DivYim1Zim1ZiWord, A15DivergenceTests,
   PPFarLeftPlacementTest, StageDeltaDiagnostics];

ZWord[i_Integer] := Block[{$labelCounter = 0}, With[{l = pairLabel[]},
   {Term[1, {U[cp[i], Cov[l]], U[cm[i], Con[l]]}]}
]];

DivYim1Word[i_Integer] := Block[{$labelCounter = 0}, With[{l1 = pairLabel[], l2 = pairLabel[]},
   {Term[1, {U[cyc[i], Cov[l1]], P[cyc[i], Con[l1]],
             U[cm[i], Cov[l2]], P[cyc[i], Con[l2]]}]}
]];

DivYim1Zim1ZiWord[i_Integer] := Block[{$labelCounter = 0},
 Module[{l1 = pairLabel[], l2 = pairLabel[], l3 = pairLabel[], l4 = pairLabel[], im = cm[i], ii = cyc[i]},
   {Term[1, {
      U[ii, Cov[l1]], P[ii, Con[l1]],                         (* Div_i *)
      U[im, Cov[l2]], P[ii, Con[l2]],                         (* y_{i-1} *)
      U[cp[im], Cov[l3]], U[cm[im], Con[l3]],                 (* z_{i-1} *)
      U[cp[ii], Cov[l4]], U[cm[ii], Con[l4]]                  (* z_i *)
   }]}
 ]
];

A15DivergenceTests[opts : OptionsPattern[]] := Module[
   {lambda = optionLookup["Lambda", opts], d = optionLookup["Dim", opts], cases, red, poly, expected},
   cases = Flatten[Table[
      {
        <|"Test" -> "Div" <> ToString[i] <> " y" <> ToString[cm[i]] <> " transport",
          "Input" -> DivYim1Word[i],
          "Expected" -> -(d - 1) lambda z[cp[i]]|>,
        <|"Test" -> "Div" <> ToString[i] <> " y" <> ToString[cm[i]] <> " z" <> ToString[cm[i]] <> " z" <> ToString[i] <> " transport",
          "Input" -> DivYim1Zim1ZiWord[i],
          "Expected" -> -d lambda z[1] z[2] z[3]|>
      },
      {i, 1, 3}], 1];
   Table[
      red = ReduceAdS[cases[[r]]["Input"], opts];
      poly = ToYZPolynomial[red];
      expected = cases[[r]]["Expected"];
      <|"Test" -> cases[[r]]["Test"],
        "Polynomial" -> poly,
        "Expected" -> expected,
        "Difference" -> Simplify[poly - expected],
        "CanonicalQ" -> CanonicalQ[red],
        "ReducedTerms" -> red|>,
