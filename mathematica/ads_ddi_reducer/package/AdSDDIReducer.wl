(* ::Package:: *)

BeginPackage["AdSDDIReducer`"];

$AdSDDIReducerVersion::usage = "$AdSDDIReducerVersion gives the reducer bundle version.";

Term::usage = "Term[c, ops] is an ordered noncommutative operator term.";
U::usage = "U[i, idx] is the auxiliary derivative partial/partial a_i with ordered index idx.";
P::usage = "P[i, idx] is the AdS covariant derivative nabla_i with ordered index idx.";
A::usage = "A[i, idx] is an explicit auxiliary vector a_i generated by curvature commutators.";
Comm::usage = "Comm[i, mu, nu, tag] is a delayed same-field derivative commutator produced in Y'/Div stages.";
RawPComm::usage = "RawPComm[i, mu, nu, tag] is a delayed same-field derivative commutator produced in P.P/Box stages.";
Pmarked::usage = "Pmarked[i, idx, tag] is a temporary selected derivative marker used by movement stages.";
Cov::usage = "Cov[label] is a lower dummy index label.";
Con::usage = "Con[label] is an upper dummy index label.";

USlot::usage = "USlot[i] is an unindexed raw DDI slot that becomes U[i, idx] after antisymmetrisation.";
PSlot::usage = "PSlot[i] is an unindexed raw DDI slot that becomes P[i, idx] after antisymmetrisation.";
Uop::usage = "Uop[i] is an alias for USlot[i].";
Pop::usage = "Pop[i] is an alias for PSlot[i].";

ZVertex::usage = "ZVertex[{n1,n2,n3}] returns ordered U-operator factors for z[1]^n1 z[2]^n2 z[3]^n3. Integer powers expand explicitly; symbolic powers are represented by ZPow and handled by Leibniz rules during A-cleanup.";
ZPow::usage = "ZPow[i,n] is an internal symbolic block representing z[i]^n=(U[i+1].U[i-1])^n. It is acted on by A-cleanup through a Leibniz rule.";
MakeDDI::usage = "MakeDDI[lowerSlots, upperSlots, n] antisymmetrises the four lower slots into 24 signed terms, appends the upper slots and z^n vertex, and returns a list of Term[c, ops].";
MakeDDIOrdered::usage = "MakeDDIOrdered[lowerSlots, upperSlots, n, order] gives explicit control of the raw eight-factor ordering.";
DDIOrderings::usage = "DDIOrderings[] lists available raw eight-factor orderings.";
DDI1Raw::usage = "DDI1Raw[i,{n1,n2,n3}] gives raw DDI 1; use {0,0,0} for V=1.";
B1Raw::usage = "B1Raw is an alias for DDI1Raw.";
DDI2Raw::usage = "DDI2Raw[i,{n1,n2,n3}] gives raw DDI 2; use {0,0,0} for V=1.";
B2Raw::usage = "B2Raw is an alias for DDI2Raw.";
DDI3Raw::usage = "DDI3Raw[i,{n1,n2,n3}] gives raw DDI 3; use {0,0,0} for V=1.";
B3Raw::usage = "B3Raw is an alias for DDI3Raw.";
DDI4Raw::usage = "DDI4Raw[i,{n1,n2,n3}] gives raw DDI 4; use {0,0,0} for V=1.";
B4Raw::usage = "B4Raw is an alias for DDI4Raw.";
DDI5Raw::usage = "DDI5Raw[i,{n1,n2,n3}] gives raw DDI 5; use {0,0,0} for V=1.";
B5Raw::usage = "B5Raw is an alias for DDI5Raw.";
ThreeDerivativeDDIRaws::usage = "ThreeDerivativeDDIRaws[i,{0,0,0}] returns an association of the three V=1 three-derivative raw DDIs B3, B4 and B5.";
DDI6Raw::usage = "DDI6Raw[i,{n1,n2,n3}] gives raw DDI 6; use {0,0,0} for V=1.";
B6Raw::usage = "B6Raw is an alias for DDI6Raw.";
DDI7Raw::usage = "DDI7Raw[i,{n1,n2,n3}] gives raw DDI 7; use {0,0,0} for V=1.";
B7Raw::usage = "B7Raw is an alias for DDI7Raw.";
DDI8Raw::usage = "DDI8Raw[i,{n1,n2,n3}] gives raw DDI 8; use {0,0,0} for V=1.";
B8Raw::usage = "B8Raw is an alias for DDI8Raw.";
DDI9Raw::usage = "DDI9Raw[i,{n1,n2,n3}] gives raw DDI 9; use {0,0,0} for V=1.";
B9Raw::usage = "B9Raw is an alias for DDI9Raw.";
DDI10Raw::usage = "DDI10Raw[i,{n1,n2,n3}] gives raw DDI 10; use {0,0,0} for V=1.";
B10Raw::usage = "B10Raw is an alias for DDI10Raw.";
FourDerivativeDDIRaws::usage = "FourDerivativeDDIRaws[i,{0,0,0}] returns an association of the five V=1 four-derivative raw DDIs B6--B10.";
AppendYToRaw::usage = "AppendYToRaw[raw,j] appends the canonical ordered y[j]=U_j.P_{j+1} factors to every raw term; used for product DDI representatives.";

CleanA::usage = "CleanA[expr] resolves all explicit A_i factors by moving them left through earlier U_i factors, branching on the metric contraction, and dropping leftmost unresolved A_i branches.";
RemoveTraces::usage = "RemoveTraces[expr] drops terms containing genuine same-field auxiliary traces U_i.U_i.";
ExpandCommutators::usage = "ExpandCommutators[expr] expands all delayed Comm and RawPComm tags using the AdS curvature rules.";
ReduceAdS::usage = "ReduceAdS[expr] repeatedly applies the ordered pipeline: A cleanup, trace removal, Y' reductions, A cleanup, Div reductions, A cleanup, P.P reductions, A cleanup, Box reductions, A cleanup, trace removal.";
ReduceAdSDiagnostics::usage = "ReduceAdSDiagnostics[expr] returns one-cycle and full-cycle stage diagnostics for the reducer pipeline.";

ToYZPolynomial::usage = "ToYZPolynomial[expr] projects a reduced ordered expression to a commutative polynomial in y[i], z[i] plus diagnostic noncanonical heads yp, div, pp, box, tr, raw.";
CanonicalQ::usage = "CanonicalQ[expr] is True iff ToYZPolynomial[expr] contains only y[i] and z[i] contractions.";
NonCanonicalReport::usage = "NonCanonicalReport[expr] returns an association counting unresolved A, Comm, RawPComm, Pmarked, trace, Y', Div, mixed P.P and Box structures.";
PipelineStages::usage = "PipelineStages[] returns the ordered reducer cycle as a list of stage names.";
TermCount::usage = "TermCount[expr] is the number of ordered terms after combining.";
PrettyTerm::usage = "PrettyTerm[Term[c,ops]] prints a readable ordered term.";
PrettyExpr::usage = "PrettyExpr[expr] prints a readable list of ordered terms.";

MakeTermFromContractions::usage = "MakeTermFromContractions[coeff,{factors...}] turns readable contractions y[i], z[i], yp[i], div[i], pp[i,j], box[i], tr[i], or raw U/P/A ops into a one-term ordered expression Term[coeff, ops].";
AsReducerExpression::usage = "AsReducerExpression[input] converts Term, list of Terms, list of raw U/P/A ops, or list of readable contraction factors into the reducer expression format.";
PipelineRun::usage = "PipelineRun[input] sends a user-entered term/expression through ReduceAdS and returns an association with input, reduced terms, Y/Z polynomial, canonical flag and noncanonical report.";
ReduceToYZ::usage = "ReduceToYZ[input] is a compact helper returning ToYZPolynomial[ReduceAdS[AsReducerExpression[input]]].";
IndexedOps::usage = "IndexedOps[\"U3^dU3_d...\"] parses compact indexed text into ordered U/P/A operators. Superscript ^ gives Con[label], subscript _ gives Cov[label]. Bare labels in concatenated words stop at the next U/P/A field token; use spaces or * around multi-letter labels when desired.";
IndexedTerm::usage = "IndexedTerm[\"U3^dU3_d...\", coeff:1] parses compact indexed text into a one-term reducer expression {Term[coeff, ops]}.";
IndexedPipelineRun::usage = "IndexedPipelineRun[\"U3^dU3_d...\"] parses compact indexed text and runs PipelineRun through the strict reducer.";
IndexedReduceToYZ::usage = "IndexedReduceToYZ[\"U3^dU3_d...\"] parses compact indexed text and returns the reduced Y/Z polynomial.";
IndexedParserRegressionTests::usage = "IndexedParserRegressionTests[] checks compact indexed parser inputs, including concatenated, space-separated, *-separated, and multi-letter separated labels.";
CoolIndexedWords::usage = "CoolIndexedWords[] returns an association of compact indexed example words for parser/reducer stress tests.";
TermOps::usage = "TermOps[\"U3^dU3_d...\"] is a readable alias for IndexedOps.";
TermPipeline::usage = "TermPipeline[\"U3^dU3_d...\"] is a readable alias for IndexedPipelineRun.";
TermReduce::usage = "TermReduce[\"U3^dU3_d...\"] is a readable alias for IndexedReduceToYZ.";
LichnerowiczFormulaRHS::usage = "LichnerowiczFormulaRHS[i, mu, nu, tail] gives the ordered RHS of the constant-curvature commutator [P_i[mu],P_i[nu]] acting on a derivative tail, before A-cleanup; useful for independent checks of ExpandCommutators.";
LichnerowiczCommutatorTests::usage = "LichnerowiczCommutatorTests[] runs local higher-spin curvature checks for the direct field action and one/two-derivative tail pieces of the Lichnerowicz commutator formula.";
LichnerowiczCommutatorDetails::usage = "LichnerowiczCommutatorDetails[] returns the same Lichnerowicz checks but includes raw before-A-cleanup commutator expansions as well as cleaned comparisons.";
StageReduce::usage = "StageReduce[stage,input] applies one named reducer stage/block to a user expression. Stages include ACleanup, TraceRemoval, ExpandCommutators, Yp1/Yp2/Yp3/YpBlock, Div1/Div2/Div3/DivBlock, PP32/PP31/PP12/PPBlock, Box1/Box2/Box3/BoxBlock, FullCycle.";
StagePipelineRun::usage = "StagePipelineRun[stages,input] applies a list of StageReduce names in order and returns rows with the expression, polynomial and noncanonical report after each stage.";
ReducerStageTestSuite::usage = "ReducerStageTestSuite[] returns a compact association of example inputs/outputs for each stage of the reducer and several chained block examples.";

y::usage = "y[i] denotes the canonical contraction U_i.P_{i+1}.";
z::usage = "z[i] denotes the canonical contraction U_{i+1}.U_{i-1}.";
yp::usage = "yp[i] is a diagnostic noncanonical contraction U_i.P_{i-1}.";
div::usage = "div[i] is a diagnostic divergence U_i.P_i.";
pp::usage = "pp[i,j] is a diagnostic mixed derivative contraction P_i.P_j.";
box::usage = "box[i] is a diagnostic box P_i.P_i.";
tr::usage = "tr[i] is a diagnostic trace U_i.U_i.";
raw::usage = "raw[...] marks a noncanonical leftover index group in ToYZPolynomial.";

YpWord::usage = "YpWord[i] gives the one-term expression U_i.P_{i-1}, useful for testing.";
YWord::usage = "YWord[i] gives the canonical one-term expression U_i.P_{i+1}.";
DivWord::usage = "DivWord[i] gives U_i.P_i.";
PPWord::usage = "PPWord[i,j] gives P_i.P_j.";
PPFarLeftPlacementTest::usage = "PPFarLeftPlacementTest[] checks that a selected mixed P.P pair is moved to the far left through its full ordered environment before IBP.";
BoxWord::usage = "BoxWord[i] gives P_i.P_i.";
BoxRightTailProbe::usage = "BoxRightTailProbe[] returns a scalar ordered word in which a selected Box1 must move right across another same-field P1 before mass reduction.";
BoxRightTailProbeTest::usage = "BoxRightTailProbeTest[] reduces BoxRightTailProbe[] and reports whether the box-stage candidate-list bug is absent.";
TraceWord::usage = "TraceWord[i] gives U_i.U_i.";
BasicReducerTests::usage = "BasicReducerTests[] returns elementary pipeline-only checks for Y', Div, P.P, Box, trace and A cleanup.";
YpFarLeftPlacementWord::usage = "YpFarLeftPlacementWord[] is the local word -y2 y'3 z2 z3 used to verify that the Y' derivative is physically moved to the far left before IBP.";
YpFarLeftPlacementTest::usage = "YpFarLeftPlacementTest[] checks the local far-left Y' placement rule: -y2 y'3 z2 z3 -> y2 y3 z2 z3 - Dim Lambda z1 z2 z3.";

ZWord::usage = "ZWord[i] gives the one-term expression z[i]=U[i+1].U[i-1].";
DivYim1Word::usage = "DivYim1Word[i] gives the ordered local word Div_i y_{i-1}, used to test divergence transport.";
DivYim1Zim1ZiWord::usage = "DivYim1Zim1ZiWord[i] gives Div_i y_{i-1} z_{i-1} z_i, the local motif responsible for the B1 Div-stage curvature shift.";
A15DivergenceTests::usage = "A15DivergenceTests[] returns local tests of Div_i reduction and curvature transport.";
StageDeltaDiagnostics::usage = "StageDeltaDiagnostics[diag] converts ReduceAdSDiagnostics rows into stage-to-stage polynomial deltas.";
ZPowerSimplify::usage = "ZPowerSimplify[expr] performs formal algebraic simplification of z[i]^a z[i]^b powers, appropriate for polynomial/formal-vertex diagnostics.";
SymbolicZPowers::usage = "SymbolicZPowers[] returns {Global`n1,Global`n2,Global`n3}.";
DDIRawByKey::usage = "DDIRawByKey[\"B1\"|...|\"B10\", i, n] returns the raw ordered DDI expression.";
