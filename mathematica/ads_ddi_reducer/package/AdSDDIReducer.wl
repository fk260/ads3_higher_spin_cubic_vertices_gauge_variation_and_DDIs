StageDeltaDiagnostics[diag_List] := Table[
   <|"From" -> diag[[r - 1]]["Stage"],
     "To" -> diag[[r]]["Stage"],
     "Delta" -> Simplify[diag[[r]]["Polynomial"] - diag[[r - 1]]["Polynomial"]]|>,
   {r, 2, Length[diag]}
];

(* ---------------------------------------------------------------------- *)
(* public stage-level test helpers                                          *)
(* ---------------------------------------------------------------------- *)

ClearAll[stageExpr, StageReduce, StagePipelineRun, stageReportRow,
   ReducerStageTestSuite, indexedOrExpr];

indexedOrExpr[x_String, opts___Rule] := IndexedTerm[x, opts];
indexedOrExpr[x_, opts___Rule] := AsReducerExpression[x, opts];

stageExpr[input_, opts___Rule] := Module[{expr = indexedOrExpr[input, opts]},
   If[expr === $Failed, $Failed, combine[expr]]
];

StageReduce::badstage = "Unknown reducer stage `1`. Try ACleanup, TraceRemoval, ExpandCommutators, Yp1/Yp2/Yp3/YpBlock, Div1/Div2/Div3/DivBlock, PP32/PP31/PP12/PPBlock, Box1/Box2/Box3/BoxBlock, FullCycle, or FullReduce.";

StageReduce[stage_String, input_, opts : OptionsPattern[]] := Module[{expr = stageExpr[input, opts], st = StringReplace[stage, WhitespaceCharacter .. -> ""]},
   If[expr === $Failed, Return[$Failed]];
   Switch[st,
      "ACleanup" | "Acleanup" | "A", CleanA[expr, opts],
      "TraceRemoval" | "RemoveTraces" | "Trace", RemoveTraces[expr, opts],
      "StartCleanup", StartCleanup[expr, opts],
      "EndCleanup", EndCleanup[expr, opts],
      "ExpandCommutators", postCommCleanup[expr, opts],
      "ExpandCommutatorsRaw", ExpandCommutators[expr, opts],
      "Yp1", repeatStage[expr, hasYp[#, 1] &, reduceOneYp[#, 1, opts] &, opts],
      "Yp2", repeatStage[expr, hasYp[#, 2] &, reduceOneYp[#, 2, opts] &, opts],
      "Yp3", repeatStage[expr, hasYp[#, 3] &, reduceOneYp[#, 3, opts] &, opts],
      "YpBlock", Fold[Function[{acc, j}, repeatStage[acc, Function[e, hasYp[e, j]], Function[e, reduceOneYp[e, j, opts]], opts]], expr, {3, 2, 1}],
      "Div1", repeatStage[expr, hasDiv[#, 1] &, reduceOneDiv[#, 1, opts] &, opts],
      "Div2", repeatStage[expr, hasDiv[#, 2] &, reduceOneDiv[#, 2, opts] &, opts],
      "Div3", repeatStage[expr, hasDiv[#, 3] &, reduceOneDiv[#, 3, opts] &, opts],
      "DivBlock", Fold[Function[{acc, j}, repeatStage[acc, Function[e, hasDiv[e, j]], Function[e, reduceOneDiv[e, j, opts]], opts]], expr, {3, 2, 1}],
      "PP32", repeatStage[expr, hasPP[#, 3, 2] &, reduceOnePP[#, 3, 2, opts] &, opts],
      "PP31", repeatStage[expr, hasPP[#, 3, 1] &, reduceOnePP[#, 3, 1, opts] &, opts],
      "PP12", repeatStage[expr, hasPP[#, 1, 2] &, reduceOnePP[#, 1, 2, opts] &, opts],
      "PPBlock", Fold[Function[{acc, pair}, repeatStage[acc, Function[e, hasPP[e, pair[[1]], pair[[2]]]], Function[e, reduceOnePP[e, pair[[1]], pair[[2]], opts]], opts]], expr, {{3, 2}, {3, 1}, {1, 2}}],
      "Box1", repeatStage[expr, hasBox[#, 1] &, reduceOneBox[#, 1, opts] &, opts],
      "Box2", repeatStage[expr, hasBox[#, 2] &, reduceOneBox[#, 2, opts] &, opts],
      "Box3", repeatStage[expr, hasBox[#, 3] &, reduceOneBox[#, 3, opts] &, opts],
      "BoxBlock", Fold[Function[{acc, j}, repeatStage[acc, Function[e, hasBox[e, j]], Function[e, reduceOneBox[e, j, opts]], opts]], expr, {3, 2, 1}],
      "FullCycle", cycleReduce[expr, opts],
      "FullReduce" | "ReduceAdS", ReduceAdS[expr, opts],
      _, Message[StageReduce::badstage, stage]; $Failed
   ]
];

stageReportRow[name_String, expr_List] := <|
   "Stage" -> name,
   "TermCount" -> TermCount[expr],
   "Polynomial" -> ToYZPolynomial[expr],
   "CanonicalQ" -> CanonicalQ[expr],
   "NonCanonicalReport" -> NonCanonicalReport[expr],
   "Terms" -> expr|>;

StagePipelineRun[stages_List, input_, opts : OptionsPattern[]] := Module[{expr = stageExpr[input, opts], rows = {}, next},
   If[expr === $Failed, Return[$Failed]];
   AppendTo[rows, stageReportRow["Input", expr]];
   Do[
      next = StageReduce[st, expr, opts];
      If[next === $Failed, Return[$Failed]];
      expr = next;
      AppendTo[rows, stageReportRow[st, expr]],
      {st, stages}
   ];
   rows
];
StagePipelineRun[stage_String, input_, opts : OptionsPattern[]] := StagePipelineRun[{stage}, input, opts];

ReducerStageTestSuite[opts : OptionsPattern[]] := Module[
   {wordTrace, wordMixed, cases, runOne, ppSmokeInput, chained},
   wordTrace = "U3^dU3_dU2^cU1_aP1_aP1_cP1_bP1^b";
   wordMixed = "U3^dU2_dU2^cU1_aP1_aP1_cP1_bP1^b";
   ppSmokeInput = Block[{$labelCounter = 0}, Module[{a = pairLabel[], b = pairLabel[], c = pairLabel[]},
      {Term[1, {U[3, Cov[a]], U[1, Con[a]], P[1, Cov[b]], U[2, Con[c]], P[2, Con[b]], U[3, Cov[c]]}]}
   ]];
   cases = <|
      "A cleanup: U1^a A1_a -> Dim" -> {"ACleanup", "U1^aA1_a"},
      "Trace removal: U3^a U3_a -> 0" -> {"TraceRemoval", "U3^aU3_a"},
      "Yp1: U1.P3 -> -U1.P2 - Div1" -> {"Yp1", YpWord[1]},
      "Yp far-left block: -y2 y'3 z2 z3" -> {"YpBlock", YpFarLeftPlacementWord[]},
      "Div1 terminal drop: U1.P1 -> 0" -> {"Div1", DivWord[1]},
      "Div block A15 motif: Div_i y_{i-1} z_{i-1} z_i" -> {"DivBlock", DivYim1Zim1ZiWord[1]},
      "P.P IBP: P1.P2 -> 1/2(Box3-Box1-Box2)" -> {"PP12", PPWord[1, 2]},
      "P.P far-left smoke word" -> {"PPBlock", ppSmokeInput},
      "Box1 on-shell: P1.P1 -> m1" -> {"Box1", BoxWord[1]},
      "Box tail probe" -> {"BoxBlock", BoxRightTailProbe[]},
      "User indexed term with U3 trace" -> {"FullReduce", wordTrace},
      "User indexed mixed nontrivial term" -> {"FullReduce", wordMixed}
   |>;
   runOne[{stage_, input_}] := Module[{out = StageReduce[stage, input, opts]},
      <|"Stage" -> stage,
        "Input" -> input,
        "OutputTerms" -> out,
        "OutputPolynomial" -> If[out === $Failed, $Failed, ToYZPolynomial[out]],
        "CanonicalQ" -> If[out === $Failed, False, CanonicalQ[out]],
        "Report" -> If[out === $Failed, $Failed, NonCanonicalReport[out]]|>
   ];
   chained = <|
      "Yp then Div on far-left motif" -> StagePipelineRun[{"StartCleanup", "YpBlock", "ACleanup", "DivBlock"}, YpFarLeftPlacementWord[], opts],
      "Full reducer cycle on same motif" -> StagePipelineRun[{"FullCycle", "FullReduce"}, YpFarLeftPlacementWord[], opts],
      "Trace term through StartCleanup then FullReduce" -> StagePipelineRun[{"StartCleanup", "FullReduce"}, wordTrace, opts],
      "Mixed term through full ordered cycle" -> StagePipelineRun[{"StartCleanup", "YpBlock", "ACleanup", "DivBlock", "ACleanup", "PPBlock", "ACleanup", "BoxBlock", "EndCleanup"}, wordMixed, opts]
   |>;
   <|"IndexedParserRegressionTests" -> IndexedParserRegressionTests[opts],
     "SingleStageExamples" -> AssociationMap[runOne[cases[#]] &, Keys[cases]],
     "ChainedExamples" -> chained|>
];



(* ---------------------------------------------------------------------- *)
(* formal z-power utilities and raw DDI lookup                              *)
(* ---------------------------------------------------------------------- *)

ClearAll[ZPowerSimplify, SymbolicZPowers, DDIRawByKey, DDIRaw];

ZPowerSimplify[expr_] := Simplify[PowerExpand[Expand[expr]]];
SymbolicZPowers[] := ToExpression /@ {"Global`n1", "Global`n2", "Global`n3"};

DDIRawByKey[k_String, i_Integer : 1, n_List : {0, 0, 0}] := Switch[k,
   "DDI1" | "B1", B1Raw[i, n],
   "DDI2" | "B2", B2Raw[i, n],
   "DDI3" | "B3", B3Raw[i, n],
   "DDI4" | "B4", B4Raw[i, n],
   "DDI5" | "B5", B5Raw[i, n],
   "DDI6" | "B6", B6Raw[i, n],
   "DDI7" | "B7", B7Raw[i, n],
   "DDI8" | "B8", B8Raw[i, n],
   "DDI9" | "B9", B9Raw[i, n],
   "DDI10" | "B10", B10Raw[i, n],
   _, $Failed
];

DDIRaw[k_String, i_Integer : 1, n_List : {0, 0, 0}, opts : OptionsPattern[]] := DDIRawByKey[k, i, n];

installAdSReducerOptions[];
