TermOps[word_String, opts : OptionsPattern[]] := IndexedOps[word, opts];
TermPipeline[word_String, opts : OptionsPattern[]] := IndexedPipelineRun[word, opts];
TermPipeline[word_String, coeff_, opts : OptionsPattern[]] := IndexedPipelineRun[word, coeff, opts];
TermReduce[word_String, opts : OptionsPattern[]] := IndexedReduceToYZ[word, opts];
TermReduce[word_String, coeff_, opts : OptionsPattern[]] := IndexedReduceToYZ[word, coeff, opts];

IndexedTerm[word_String, opts : OptionsPattern[]] := IndexedTerm[word, 1, opts];
IndexedTerm[word_String, coeff_, opts : OptionsPattern[]] := Module[{ops = IndexedOps[word, opts]},
   If[ops === $Failed, $Failed, combine[{Term[coeff, ops]}]]
];

IndexedPipelineRun[word_String, opts : OptionsPattern[]] := Module[{expr = IndexedTerm[word, 1, opts]},
   If[expr === $Failed, $Failed, PipelineRun[expr, opts]]
];
IndexedPipelineRun[word_String, coeff_, opts : OptionsPattern[]] := Module[{expr = IndexedTerm[word, coeff, opts]},
   If[expr === $Failed, $Failed, PipelineRun[expr, opts]]
];

IndexedReduceToYZ[word_String, opts : OptionsPattern[]] := Module[{r = IndexedPipelineRun[word, opts]},
   If[r === $Failed, $Failed, r["Polynomial"]]
];
IndexedReduceToYZ[word_String, coeff_, opts : OptionsPattern[]] := Module[{r = IndexedPipelineRun[word, coeff, opts]},
   If[r === $Failed, $Failed, r["Polynomial"]]
];


(* ---------------------------------------------------------------------- *)
(* Lichnerowicz / AdS commutator formula checks                            *)
(* ---------------------------------------------------------------------- *)

ClearAll[negateExpr, prependOpsToTerms, LichnerowiczFormulaRHS,
   lichnerowiczProbe, lichnerowiczCompare, LichnerowiczCommutatorTests,
   LichnerowiczCommutatorDetails, lichnerowiczProbeRaw, lichnerowiczCompareDetails];

negateExpr[expr_List] := combine[expr /. Term[c_, ops_List] :> Term[-c, ops]];
prependOpsToTerms[prefix_List, expr_List] := combine[expr /. Term[c_, ops_List] :> Term[c, Join[prefix, ops]]];

(* Constant-curvature/Lichnerowicz commutator in the package conventions:
      [P_i[mu],P_i[nu]]_field = -lambda A_i[mu] U_i[nu] + lambda A_i[nu] U_i[mu]
   and, on every same-field derivative P_i[rho] in the tail,
      [P_mu,P_nu] P_rho includes lambda g_{rho nu} P_mu - lambda g_{rho mu} P_nu.
   This function deliberately constructs the RHS independently from the delayed
   Comm/RawPComm expansion loop, then the tests compare both paths. *)
LichnerowiczFormulaRHS[i_Integer, mu_, nu_, tail_List : {}, opts : OptionsPattern[]] := Module[
   {f = cyc[i], lambda = optionLookup["Lambda", opts], out, target, rho, w, mm, r},
   out = {
      Term[-lambda, Join[{A[f, mu], U[f, nu]}, tail]],
      Term[ lambda, Join[{A[f, nu], U[f, mu]}, tail]]
   };
   Do[
      target = tail[[r]];
      If[pAnyQ[target, f],
         rho = opIndex[target];
         w = ReplacePart[tail, r -> setOpIndex[target, mu]];
         mm = metricMerge[w, rho, nu, opts];
         AppendTo[out, Term[ lambda mm[[1]], mm[[2]]]];

         w = ReplacePart[tail, r -> setOpIndex[target, nu]];
         mm = metricMerge[w, rho, mu, opts];
         AppendTo[out, Term[-lambda mm[[1]], mm[[2]]]];
      ],
      {r, Length[tail]}
   ];
   combine[out]
];

lichnerowiczProbe[i_Integer, prefix_List, mu_, nu_, tail_List, opts___Rule] := Module[
   {lhs, rhs},
   lhs = CleanA[ExpandCommutators[{Term[1, Join[prefix, {Comm[cyc[i], mu, nu, "Lich"]}, tail]]}, opts], opts];
   rhs = CleanA[prependOpsToTerms[prefix, LichnerowiczFormulaRHS[i, mu, nu, tail, opts]], opts];
   {lhs, rhs}
];

lichnerowiczCompare[name_String, i_Integer, prefix_List, mu_, nu_, tail_List, opts___Rule] := Module[
   {lhs, rhs, diff},
   {lhs, rhs} = lichnerowiczProbe[i, prefix, mu, nu, tail, opts];
   diff = combine[Join[lhs, negateExpr[rhs]]];
   <|"Test" -> name,
     "Field" -> cyc[i],
     "LHSExpandedByCommTags" -> lhs,
     "RHSFromLichnerowiczFormula" -> rhs,
     "DifferenceTerms" -> diff,
     "DifferenceTermCount" -> TermCount[diff],
     "Matches" -> TrueQ[exprKey[lhs] === exprKey[rhs]]|>
];

LichnerowiczCommutatorTests[opts : OptionsPattern[]] := Block[{$labelCounter = 0}, Module[
   {i = 1, a, b, c, mu, nu, rho, sig, prefixSpin2, prefixSpin3, tail1, tail2, tailOther},
   a = pairLabel[]; b = pairLabel[]; c = pairLabel[]; mu = Cov[pairLabel[]]; nu = Cov[pairLabel[]]; rho = Cov[pairLabel[]]; sig = Cov[pairLabel[]];
   prefixSpin2 = {U[1, Cov[a]], U[2, Con[a]], U[1, Cov[b]], U[3, Con[b]]};
   prefixSpin3 = Join[prefixSpin2, {U[1, Cov[c]], U[2, Con[c]]}];
   tail1 = {P[1, rho]};
   tail2 = {P[1, rho], P[1, sig]};
   tailOther = {P[2, rho]};
   {
      lichnerowiczCompare["direct field action on a spin-2 auxiliary probe", i, prefixSpin2, mu, nu, {}, opts],
      lichnerowiczCompare["one same-field derivative tail", i, prefixSpin2, mu, nu, tail1, opts],
      lichnerowiczCompare["two same-field derivative tails / Leibniz check", i, prefixSpin3, mu, nu, tail2, opts],
      lichnerowiczCompare["different-field derivative tail gives no derivative-tail branch", i, prefixSpin2, mu, nu, tailOther, opts]
   }
]];

lichnerowiczProbeRaw[i_Integer, prefix_List, mu_, nu_, tail_List, opts___Rule] := Module[
   {lhsRaw, rhsRaw, lhsClean, rhsClean},
   lhsRaw = ExpandCommutators[{Term[1, Join[prefix, {Comm[cyc[i], mu, nu, "LichRaw"]}, tail]]}, opts];
   rhsRaw = prependOpsToTerms[prefix, LichnerowiczFormulaRHS[i, mu, nu, tail, opts]];
   lhsClean = CleanA[lhsRaw, opts];
   rhsClean = CleanA[rhsRaw, opts];
   {lhsRaw, rhsRaw, lhsClean, rhsClean}
];

lichnerowiczCompareDetails[name_String, i_Integer, prefix_List, mu_, nu_, tail_List, opts___Rule] := Module[
   {lhsRaw, rhsRaw, lhsClean, rhsClean, diffRaw, diffClean},
   {lhsRaw, rhsRaw, lhsClean, rhsClean} = lichnerowiczProbeRaw[i, prefix, mu, nu, tail, opts];
   diffRaw = combine[Join[lhsRaw, negateExpr[rhsRaw]]];
   diffClean = combine[Join[lhsClean, negateExpr[rhsClean]]];
   <|"Test" -> name,
     "Field" -> cyc[i],
     "LHSRawByCommTags" -> lhsRaw,
     "RHSRawFromLichnerowiczFormula" -> rhsRaw,
     "RawDifferenceTerms" -> diffRaw,
     "RawDifferenceTermCount" -> TermCount[diffRaw],
     "LHSAfterACleanup" -> lhsClean,
     "RHSAfterACleanup" -> rhsClean,
     "CleanDifferenceTerms" -> diffClean,
     "CleanDifferenceTermCount" -> TermCount[diffClean],
     "RawMatches" -> TrueQ[exprKey[lhsRaw] === exprKey[rhsRaw]],
     "CleanMatches" -> TrueQ[exprKey[lhsClean] === exprKey[rhsClean]]|>
];

LichnerowiczCommutatorDetails[opts : OptionsPattern[]] := Block[{$labelCounter = 0}, Module[
   {i = 1, a, b, c, mu, nu, rho, sig, prefixSpin2, prefixSpin3, tail1, tail2, tailOther},
   a = pairLabel[]; b = pairLabel[]; c = pairLabel[]; mu = Cov[pairLabel[]]; nu = Cov[pairLabel[]]; rho = Cov[pairLabel[]]; sig = Cov[pairLabel[]];
   prefixSpin2 = {U[1, Cov[a]], U[2, Con[a]], U[1, Cov[b]], U[3, Con[b]]};
   prefixSpin3 = Join[prefixSpin2, {U[1, Cov[c]], U[2, Con[c]]}];
   tail1 = {P[1, rho]};
   tail2 = {P[1, rho], P[1, sig]};
   tailOther = {P[2, rho]};
   {
      lichnerowiczCompareDetails["direct field action on a spin-2 auxiliary probe", i, prefixSpin2, mu, nu, {}, opts],
      lichnerowiczCompareDetails["one same-field derivative tail", i, prefixSpin2, mu, nu, tail1, opts],
      lichnerowiczCompareDetails["two same-field derivative tails / Leibniz check", i, prefixSpin3, mu, nu, tail2, opts],
      lichnerowiczCompareDetails["different-field derivative tail gives no derivative-tail branch", i, prefixSpin2, mu, nu, tailOther, opts]
   }
]];


BasicReducerTests[opts : OptionsPattern[]] := Module[{cases, red, poly, expected},
   cases = {
      {"Yp1 -> -y1", YpWord[1], -y[1]},
      {"Div1 -> 0", DivWord[1], 0},
      {"P1.P2 -> 1/2(m3-m1-m2)", PPWord[1, 2], 1/2 (massValue[3, opts] - massValue[1, opts] - massValue[2, opts])},
      {"Box1 -> m1", BoxWord[1], massValue[1, opts]},
      {"Trace U1.U1 -> 0", TraceWord[1], 0},
      {"A cleanup U1.A1 contracted -> Dim", Block[{$labelCounter = 0}, With[{l = pairLabel[]}, {Term[1, {U[1, Cov[l]], A[1, Con[l]]}]}]], optionLookup["Dim", opts]}
   };
   Table[
      red = ReduceAdS[cases[[r, 2]], opts];
      poly = ToYZPolynomial[red];
      expected = cases[[r, 3]];
      <|"Test" -> cases[[r, 1]], "Polynomial" -> poly, "Expected" -> expected, "Difference" -> Simplify[poly - expected], "CanonicalQ" -> CanonicalQ[red], "ReducedTerms" -> red|>,
      {r, Length[cases]}
   ]
];

YpFarLeftPlacementWord[] := Block[{$labelCounter = 0},
   Module[{l1 = pairLabel[], l2 = pairLabel[], l3 = pairLabel[], l4 = pairLabel[]},
      {Term[-1, {
         U[2, Cov[l1]], P[3, Con[l1]],          (* y2 *)
         U[3, Cov[l2]], P[2, Con[l2]],          (* y'_3 *)
         U[3, Cov[l3]], U[1, Con[l3]],          (* z2 *)
         U[1, Cov[l4]], U[2, Con[l4]]           (* z3 *)
      }]}
   ]
];

YpFarLeftPlacementTest[opts : OptionsPattern[]] := Module[
   {lambda = optionLookup["Lambda", opts], d = optionLookup["Dim", opts], red, poly, expected},
   red = ReduceAdS[YpFarLeftPlacementWord[], opts];
   poly = ToYZPolynomial[red];
   expected = y[2] y[3] z[2] z[3] - d lambda z[1] z[2] z[3];
   <|"Test" -> "far-left Yp placement: -y2 y'3 z2 z3", "Polynomial" -> poly,
     "Expected" -> expected, "Difference" -> Simplify[poly - expected],
     "CanonicalQ" -> CanonicalQ[red], "ReducedTerms" -> red|>
];



