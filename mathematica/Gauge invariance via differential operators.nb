Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Put", " ", "the", " ", "gauge", " ", "variation", " ", "into", " ", "a", " ",
     "more", " ", "readable", " ", "form", " ", "for", " ", "the", " ", 
    "paper"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"nmSubdV2", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"dV2", "/.", "miRules"}], "/.", 
      RowBox[{"d", "->", "3"}]}], "//", "ExpandAll"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cubicYMonomials", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"y1", "^", "3"}], ",", 
       RowBox[{
        RowBox[{"y1", "^", "2"}], " ", "y2"}], ",", 
       RowBox[{
        RowBox[{"y1", "^", "2"}], " ", "y3"}], ",", 
       RowBox[{"y1", " ", 
        RowBox[{"y2", "^", "2"}]}], ",", 
       RowBox[{"y1", " ", "y2", " ", "y3"}], ",", 
       RowBox[{"y1", " ", 
        RowBox[{"y3", "^", "2"}]}], ",", 
       RowBox[{"y2", "^", "3"}], ",", 
       RowBox[{
        RowBox[{"y2", "^", "2"}], " ", "y3"}], ",", 
       RowBox[{"y2", " ", 
        RowBox[{"y3", "^", "2"}]}], ",", 
       RowBox[{"y3", "^", "3"}]}], "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dV23yPart", "=", 
     RowBox[{"Total", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{"nmSubdV2", ",", "#"}], "]"}], " ", "#"}], "&"}], "/@", 
       "cubicYMonomials"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<Three-derivative part of gauge variation:\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{"dV23yPartSimplified", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"dV23yPart", "/", 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["z1", "n1"], " ", 
            SuperscriptBox["z2", 
             RowBox[{
              RowBox[{"-", "1"}], "+", "n2"}]], " ", 
            SuperscriptBox["z3", 
             RowBox[{
              RowBox[{"-", "1"}], "+", "n3"}]]}], ")"}]}], "//", 
         "FullSimplify"}], ")"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"z1", " ", "y1"}], "+", 
        RowBox[{"z2", " ", "y2"}], "+", 
        RowBox[{"z3", " ", "y3"}]}], ")"}]}], "//", "ExpandAll"}]}], 
   "\[IndentingNewLine]", " ", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Check", " ", "equivalence", " ", "to", " ", "form", " ", "written", " ", 
     "in", " ", "paper"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"s1Coeff", "=", 
    RowBox[{"Coefficient", "[", 
     RowBox[{"dV23yPartSimplified", ",", "s1"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"s2Coeff", "=", 
    RowBox[{"Coefficient", "[", 
     RowBox[{"dV23yPartSimplified", ",", "s2"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"s3Coeff", "=", 
    RowBox[{"Coefficient", "[", 
     RowBox[{"dV23yPartSimplified", ",", "s3"}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"s1", "-", "1"}], ")"}], "*", "s1Coeff"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"s2", "-", "1"}], ")"}], "*", "s2Coeff"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"s3", "-", "1"}], ")"}], "s3Coeff"}]}], "//", "ExpandAll"}], 
     ")"}], "==", "dV23yPartSimplified"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Then", " ", "check", " ", "one", " ", "derivative", " ", "part"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<y1 \!\(\*SuperscriptBox[\(z1\), \(2 + n1\)]\) \
\!\(\*SuperscriptBox[\(z2\), \(n2\)]\) \!\(\*SuperscriptBox[\(z3\), \(n3\)]\) \
coefficient:\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{"y1Coeff", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"nmSubdV2", "-", "dV23yPart"}], "//", "ExpandAll"}], ",", 
         RowBox[{"y1", " ", 
          SuperscriptBox["z1", 
           RowBox[{"2", "+", "n1"}]], " ", 
          SuperscriptBox["z2", "n2"], " ", 
          SuperscriptBox["z3", "n3"]}]}], "]"}], "*", 
       RowBox[{"l", "^", "2"}]}], "/.", "nRules"}], "//", "ExpandAll"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<y2 \!\(\*SuperscriptBox[\(z1\), \(1 + n1\)]\) \
\!\(\*SuperscriptBox[\(z2\), \(1 + n2\)]\) \!\(\*SuperscriptBox[\(z3\), \
\(n3\)]\) coefficient:\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{"y2Coeff", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"nmSubdV2", "-", "dV23yPart"}], "//", "ExpandAll"}], ",", 
         RowBox[{"y2", " ", 
          SuperscriptBox["z1", 
           RowBox[{"1", "+", "n1"}]], " ", 
          SuperscriptBox["z2", 
           RowBox[{"1", "+", "n2"}]], " ", 
          SuperscriptBox["z3", "n3"]}]}], "]"}], "*", 
       RowBox[{"l", "^", "2"}]}], "/.", "nRules"}], "//", "ExpandAll"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<y3 \!\(\*SuperscriptBox[\(z1\), \(1 + n1\)]\) \
\!\(\*SuperscriptBox[\(z2\), \(n2\)]\) \!\(\*SuperscriptBox[\(z3\), \(1 + \
n3\)]\) coefficient:\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{"y3Coeff", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"nmSubdV2", "-", "dV23yPart"}], "//", "ExpandAll"}], ",", 
         RowBox[{"y3", " ", 
          SuperscriptBox["z1", 
           RowBox[{"1", "+", "n1"}]], " ", 
          SuperscriptBox["z2", "n2"], " ", 
          SuperscriptBox["z3", 
           RowBox[{"1", "+", "n3"}]]}]}], "]"}], "*", 
       RowBox[{"l", "^", "2"}]}], "/.", "nRules"}], "//", "ExpandAll"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", "\"\<Full one-derivative part:\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{"dV21yPart", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"l", "^", "2"}]}], ")"}], "y1", " ", 
      SuperscriptBox["z1", 
       RowBox[{"2", "+", "n1"}]], " ", 
      SuperscriptBox["z2", "n2"], " ", 
      SuperscriptBox["z3", "n3"], "*", "y1Coeff"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"l", "^", "2"}]}], ")"}], "y2", " ", 
      SuperscriptBox["z1", 
       RowBox[{"1", "+", "n1"}]], " ", 
      SuperscriptBox["z2", 
       RowBox[{"1", "+", "n2"}]], " ", 
      SuperscriptBox["z3", "n3"], "*", "y2Coeff"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"l", "^", "2"}]}], ")"}], "y3", " ", 
      SuperscriptBox["z1", 
       RowBox[{"1", "+", "n1"}]], " ", 
      SuperscriptBox["z2", "n2"], " ", 
      SuperscriptBox["z3", 
       RowBox[{"1", "+", "n3"}]], "*", "y3Coeff"}]}]}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"nmSubdV2", "-", "dV23yPart", "-", "dV21yPart"}], ")"}], "/.", 
     "nRules"}], "//", "ExpandAll"}]}]}]], "Input",
